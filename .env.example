# ─────────────────────────────────────────────────────────────────────────────
# TinaCMS self-host — contrat d'environnement (starter Astro Portfolio, Mettaton Lot 1)
# Copier en `.env.local` (jamais commité). Ne JAMAIS committer de secret (canon §6.1).
# ─────────────────────────────────────────────────────────────────────────────

# Mode local : auth + datalayer servis par `tinacms dev` (filesystem + git, sans DB).
# Mettre à `false` en prod (le backend self-host du Lot 4 prend le relais).
TINA_PUBLIC_IS_LOCAL=true

# Chemin du contenu éditable par Tina (frontière repo, canon §3). Défaut : src/content.
TINA_CONTENT_PATH=src/content

# ── Backend prod (Lot 4 — Docker/Dokploy) : laissés vides en local ────────────
# Secret AuthJS pour l'auth admin en prod (AuthJsBackendAuthProvider).
NEXTAUTH_SECRET=

# URL du backend Tina self-host (datalayer GraphQL) — pointée par contentApiUrlOverride.
TINA_PUBLIC_CONTENT_API_URL=

# Identifiants du backend distant (Tina Cloud OU self-host). Vides en local.
TINA_PUBLIC_CLIENT_ID=
TINA_TOKEN=

# Branche Git éditée par le backend.
GITHUB_BRANCH=main

# ── Git provider (Lot 4 — facteur différenciant multi-forge, canon §2) ────────
# GitHub natif :
# GITHUB_OWNER=
# GITHUB_REPO=
# GITHUB_PERSONAL_ACCESS_TOKEN=
# Forge alternative (GitLab/Gitea/Forgejo/Bitbucket) : provider custom + token à portée limitée.
# GIT_PROVIDER=
# GIT_PROVIDER_TOKEN=
# GIT_PROVIDER_BASE_URL=

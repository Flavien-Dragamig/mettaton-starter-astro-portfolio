# ─────────────────────────────────────────────────────────────────────────────
# TinaCMS self-host — contrat d'environnement (starter Astro Portfolio, Mettaton)
# Copier en `.env.local` (jamais commité). Ne JAMAIS committer de secret (canon §6.1).
# ─────────────────────────────────────────────────────────────────────────────

# Mode local : auth + datalayer servis par `tinacms dev` (filesystem + git, sans DB).
# Mettre à `false` en prod (le backend self-host conteneurisé prend le relais).
TINA_PUBLIC_IS_LOCAL=true

# Chemin du contenu éditable par Tina (frontière repo, canon §3). Défaut : src/content.
TINA_CONTENT_PATH=src/content

# ─────────────────────────────────────────────────────────────────────────────
# Backend prod (Lot 4a — Dockerfile.backend / Dokploy)
# Variables injectées par le gestionnaire de secrets de l'hôte (Dokploy), JAMAIS
# via l'UI portail (canon §7.4). Laissées vides en local (mode `tinacms dev`).
# ─────────────────────────────────────────────────────────────────────────────

# Secret AuthJS pour l'auth admin en prod (AuthJsBackendAuthProvider). Requis si IS_LOCAL=false.
# Générer : `openssl rand -base64 32`.
NEXTAUTH_SECRET=

# Port d'écoute du serveur backend (défaut 4001).
PORT=4001

# URL publique du backend (admin SPA + CORS). Ex : https://tina.mon-site.fr
TINA_PUBLIC_SITE_URL=

# URL du backend Tina self-host (datalayer GraphQL) — pointée par contentApiUrlOverride.
TINA_PUBLIC_CONTENT_API_URL=

# Identifiants Tina Cloud (NON utilisés en self-host). Vides.
TINA_PUBLIC_CLIENT_ID=
TINA_TOKEN=

# ── Git provider (commits du contenu — facteur différenciant multi-forge, canon §2) ──
# Branche Git éditée par le backend.
GITHUB_BRANCH=main
# GitHub natif (token à PORTÉE 1 REPO) — requis en prod self-host :
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_PERSONAL_ACCESS_TOKEN=
# Forge alternative (GitLab/Gitea/Forgejo/Bitbucket) : provider custom (Lot 5).
# GIT_PROVIDER=
# GIT_PROVIDER_TOKEN=
# GIT_PROVIDER_BASE_URL=

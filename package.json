{
  "name": "mettaton-starter-astro-portfolio",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:cms": "tinacms dev -c \"astro dev\"",
    "build": "npm run tina:build && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "tina:build": "TINA_PUBLIC_IS_LOCAL=true tinacms build --local --skip-cloud-checks --skip-indexing",
    "backend:bundle": "node tina/backend/build.mjs",
    "backend:start": "node dist-backend/server.mjs"
  },
  "dependencies": {
    "@tinacms/cli": "^2.4.4",
    "@tinacms/datalayer": "^2.0.23",
    "astro": "^6.4.6",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^4.22.2",
    "memory-level": "^3.1.0",
    "sharp": "^0.34.3",
    "tinacms": "^3.9.1",
    "tinacms-authjs": "^23.0.1",
    "tinacms-gitprovider-github": "^4.1.10"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4"
  }
}
